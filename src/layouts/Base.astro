---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Discover Anime' } = Astro.props;
---

<!doctype html>
<html lang="my">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-text">AURA&nbsp;Channel</span>
      </a>

<a href="/donate" class="header-donate" title="ကော်ဖီတိုက်မည်">
  <div class="donate-icon-wrapper">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
      <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
      <line x1="6" y1="2" x2="6" y2="4"></line>
      <line x1="10" y1="2" x2="10" y2="4"></line>
      <line x1="14" y1="2" x2="14" y2="4"></line>
    </svg>
  </div>
  <span class="donate-text">ကော်ဖီတိုက်မည်</span>
</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-content">
        <div class="footer-nav">
          <a href="/about" class="footer-nav-link">About Us</a>
          <a href="/terms" class="footer-nav-link">Terms & Policies</a>
        </div>

        <p class="footer-disclaimer">
          <strong>Disclaimer:</strong> This site does not store any files on its server. All contents are provided by non-affiliated third parties.
        </p>

        <div class="footer-bottom">
          <span class="copyright">&copy; {new Date().getFullYear()} AURA Channel. All rights reserved. <span style="opacity: 0.5; font-size: 0.8em; margin-left: 0.5rem;">v1.0.0</span></span>
        </div>
      </div>
    </footer>

    <button id="scroll-to-top" class="scroll-to-top" aria-label="Back to top">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <script>
      const scrollTopBtn = document.getElementById('scroll-to-top');

      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollTopBtn.classList.add('show');
        } else {
          scrollTopBtn.classList.remove('show');
        }
      });

      scrollTopBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth' 
        });
      });
    </script>
  </body>
</html>
