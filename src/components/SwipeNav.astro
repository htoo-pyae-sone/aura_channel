---
interface PageLink {
  href: string;
  label: string;
}

interface Props {
  pages: PageLink[];
  current: string;
}

const { pages, current } = Astro.props;
const currentIndex = pages.findIndex((p) => p.href === current);

const prevPage = currentIndex > 0 ? pages[currentIndex - 1].href : null;
const nextPage = currentIndex < pages.length - 1 ? pages[currentIndex + 1].href : null;
---

<div
  class="swipe-nav"
  data-pages={JSON.stringify(pages.map((p) => p.href))}
  data-current={currentIndex}
>
  <a class={`nav-arrow ${!prevPage ? 'is-hidden' : ''}`} href={prevPage || '#'} aria-label="Previous page">
    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </a>

  <div class="swipe-dots">
    {
      pages.map((p, i) => (
        <a
          class={`swipe-dot ${i === currentIndex ? 'is-active' : ''}`}
          href={p.href}
          aria-label={p.label}
          aria-current={i === currentIndex ? 'page' : undefined}
        />
      ))
    }
  </div>

  <a class={`nav-arrow ${!nextPage ? 'is-hidden' : ''}`} href={nextPage || '#'} aria-label="Next page">
    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </a>
</div>

<script>
  function initSwipeNav() {
    const nav = document.querySelector('.swipe-nav');
    if (!nav) return;
    const pages = JSON.parse(nav.getAttribute('data-pages') || '[]');
    const currentIndex = Number(nav.getAttribute('data-current'));

    let startX = 0;
    let startY = 0;
    const SWIPE_THRESHOLD = 60;

    document.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      },
      { passive: true }
    );
    document.addEventListener(
      'touchend',
      (e) => {
        const deltaX = e.changedTouches[0].clientX - startX;
        const deltaY = e.changedTouches[0].clientY - startY;

        if (Math.abs(deltaX) < SWIPE_THRESHOLD || Math.abs(deltaX) < Math.abs(deltaY)) return;

        if (deltaX < 0 && currentIndex < pages.length - 1) {
          window.location.href = pages[currentIndex + 1];
        } else if (deltaX > 0 && currentIndex > 0) {
          window.location.href = pages[currentIndex - 1];
        }
      },
      { passive: true }
    );
  }

  initSwipeNav();
</script>

<style>
  .swipe-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 2rem 0 0.5rem;
  }

  .swipe-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .swipe-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--line);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .swipe-dot:hover {
    background: var(--text-muted);
  }

  .swipe-dot.is-active {
    background: var(--accent);
    transform: scale(1.3);
  }

  .nav-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(var(--accent-rgb, 255, 255, 255), 0.05);
    color: var(--text-muted, #888);
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-arrow:hover:not(.is-hidden) {
    background: rgba(var(--accent-rgb, 255, 255, 255), 0.15);
    color: var(--accent, #fff);
    transform: scale(1.1);
  }

  .nav-arrow.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
</style>