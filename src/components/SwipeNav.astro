---
interface PageLink {
  href: string;
  label: string;
}

interface Props {
  pages: PageLink[];
  current: string;
}

const { pages, current } = Astro.props;
const currentIndex = pages.findIndex((p) => p.href === current);
---

<div
  class="swipe-nav"
  data-pages={JSON.stringify(pages.map((p) => p.href))}
  data-current={currentIndex}
>
  <div class="swipe-dots">
    {
      pages.map((p, i) => (
        <a
          class={`swipe-dot ${i === currentIndex ? 'is-active' : ''}`}
          href={p.href}
          aria-label={p.label}
          aria-current={i === currentIndex ? 'page' : undefined}
        />
      ))
    }
  </div>
</div>

<script>
  function initSwipeNav() {
    const nav = document.querySelector('.swipe-nav');
    if (!nav) return;

    const pages = JSON.parse(nav.getAttribute('data-pages') || '[]');
    const currentIndex = Number(nav.getAttribute('data-current'));

    let startX = 0;
    let startY = 0;
    const SWIPE_THRESHOLD = 60; // px — avoids accidental triggers from small drags

    document.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      },
      { passive: true }
    );

    document.addEventListener(
      'touchend',
      (e) => {
        const deltaX = e.changedTouches[0].clientX - startX;
        const deltaY = e.changedTouches[0].clientY - startY;

        // Ignore mostly-vertical swipes (normal page scrolling)
        if (Math.abs(deltaX) < SWIPE_THRESHOLD || Math.abs(deltaX) < Math.abs(deltaY)) return;

        if (deltaX < 0 && currentIndex < pages.length - 1) {
          // swiped left -> next page
          window.location.href = pages[currentIndex + 1];
        } else if (deltaX > 0 && currentIndex > 0) {
          // swiped right -> previous page
          window.location.href = pages[currentIndex - 1];
        }
      },
      { passive: true }
    );
  }

  initSwipeNav();
</script>

<style>
  .swipe-nav {
    display: flex;
    justify-content: center;
    padding: 2rem 0 0.5rem;
  }

  .swipe-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .swipe-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--line);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .swipe-dot:hover {
    background: var(--text-muted);
  }

  .swipe-dot.is-active {
    background: var(--accent);
    transform: scale(1.3);
  }
</style>