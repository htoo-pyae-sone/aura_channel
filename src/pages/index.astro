---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const entries = (await getCollection('anime')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const catalogData = entries.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  poster: entry.data.poster,
  type: entry.data.type,
  year: entry.data.year ?? null,
  status: entry.data.status ?? null,
  genres: entry.data.genres,
  rating: entry.data.rating ?? null,
  totalEpisodes: entry.data.totalEpisodes ?? null,
}));

const uniqueGenres = [...new Set(entries.flatMap((e) => e.data.genres))].sort();
const uniqueYears = [...new Set(entries.map((e) => e.data.year).filter(Boolean))].sort(
  (a, b) => b - a
);

const PAGE_SIZE = 10;
const catalogJSON = JSON.stringify(catalogData);
---

<Base title="AURA Channel">
 <h1></h1>
  <div class="filter-toolbar">
    <div class="search-field">
      <svg class="search-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.6" />
        <path d="M13.3 13.3 18 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="Search titles…"
        aria-label="Search titles"
      />
    </div>

    <div class="select-row">
      <select id="filter-type" class="filter-select" aria-label="Filter by type">
        <option value="All">All Types</option>
        <option value="Movie">Movie</option>
        <option value="Series">Series</option>
      </select>

      <select id="filter-status" class="filter-select" aria-label="Filter by status">
        <option value="All">All Status</option>
        <option value="Ongoing">Ongoing</option>
        <option value="Completed">Completed</option>
        <option value="Upcoming">Upcoming</option>
      </select>

      <select id="filter-genre" class="filter-select" aria-label="Filter by genre">
        <option value="All">All Genres</option>
        {uniqueGenres.map((g) => <option value={g}>{g}</option>)}
      </select>

      <select id="filter-year" class="filter-select" aria-label="Filter by year">
        <option value="All">All Years</option>
        {uniqueYears.map((y) => <option value={y}>{y}</option>)}
      </select>

      <button type="button" id="clear-filters" class="clear-btn">Clear</button>
    </div>
  </div>

  <p class="result-count" id="result-count" aria-live="polite"></p>
  <div class="catalog-grid" id="catalog-grid"></div>
  <p class="empty-state" id="empty-state" hidden>No titles match these filters.</p>

  <div class="load-more-wrap">
    <button type="button" id="load-more-btn" class="load-more-btn" hidden>
      Load More
    </button>
  </div>

  <script type="application/json" id="catalog-data" set:html={catalogJSON} />

  <script define:vars={{ PAGE_SIZE }}>
    const entries = JSON.parse(document.getElementById('catalog-data').textContent);
    const grid = document.getElementById('catalog-grid');
    const emptyState = document.getElementById('empty-state');
    const loadMoreBtn = document.getElementById('load-more-btn');
    const resultCount = document.getElementById('result-count');

    const searchInput = document.getElementById('search-input');
    const typeSelect = document.getElementById('filter-type');
    const statusSelect = document.getElementById('filter-status');
    const genreSelect = document.getElementById('filter-genre');
    const yearSelect = document.getElementById('filter-year');
    const clearBtn = document.getElementById('clear-filters');

    const urlParams = new URLSearchParams(window.location.search);
    const state = { 
      search: urlParams.get('q') || '', 
      type: urlParams.get('type') || 'All', 
      status: urlParams.get('status') || 'All', 
      genre: urlParams.get('genre') || 'All', 
      year: urlParams.get('year') || 'All', 
      visibleCount: PAGE_SIZE 
    };

    if (state.search) searchInput.value = state.search;
    if (state.type !== 'All') typeSelect.value = state.type;
    if (state.status !== 'All') statusSelect.value = state.status;
    if (state.genre !== 'All') genreSelect.value = state.genre;
    if (state.year !== 'All') yearSelect.value = state.year;

    function updateURL() {
      const url = new URL(window.location);
      state.search ? url.searchParams.set('q', state.search) : url.searchParams.delete('q');
      state.type !== 'All' ? url.searchParams.set('type', state.type) : url.searchParams.delete('type');
      state.status !== 'All' ? url.searchParams.set('status', state.status) : url.searchParams.delete('status');
      state.genre !== 'All' ? url.searchParams.set('genre', state.genre) : url.searchParams.delete('genre');
      state.year !== 'All' ? url.searchParams.set('year', state.year) : url.searchParams.delete('year');
      window.history.replaceState({}, '', url);
    }

    function applyFilters() {
      const q = state.search.trim().toLowerCase();
      return entries.filter((e) => {
        const searchOk = !q || e.title.toLowerCase().includes(q);
        const typeOk = state.type === 'All' || e.type === state.type;
        const statusOk = state.status === 'All' || e.status === state.status;
        const genreOk = state.genre === 'All' || e.genres.includes(state.genre);
        const yearOk = state.year === 'All' || String(e.year) === state.year;
        return searchOk && typeOk && statusOk && genreOk && yearOk;
      });
    }

    function escapeHTML(str) {
      if (!str) return '';
      return str.replace(/[&<>'"]/g, 
        tag => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
        }[tag] || tag)
      );
    }

    function cardHTML(e) {
      const bits = [e.type, e.year].filter(Boolean).join(' · ');
      const ratingBadge = e.rating ? `<span class="rating-badge">★ ${e.rating.toFixed(1)}</span>` : '';
      const epValue = typeof e.totalEpisodes === 'number' ? `${e.totalEpisodes} EP` : e.totalEpisodes || null;
      const episodeBadge = epValue ? `<span class="episode-badge"><svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="3.5" width="13" height="9" rx="1.3" stroke="currentColor" stroke-width="1.3"/><path d="M6.5 6.2 10 8l-3.5 1.8V6.2Z" fill="currentColor"/></svg>${epValue}</span>` : '';
      const statusBadge = e.status ? `<span class="status-badge status-${e.status.toLowerCase()}">${e.status}</span>` : '';
      
      // Fallback placeholder image URL (Replace with your actual default image path)
      const fallbackImg = "'/images/placeholder.png'"; 

      return `
        <a class="card" href="/anime/${e.slug}/">
          <div class="card-poster-wrap">
            <img 
              class="card-poster" 
              src="${escapeHTML(e.poster)}" 
              alt="${escapeHTML(e.title)} cover art" 
              loading="lazy" 
              decoding="async" 
              onerror="this.onerror=null;this.src=${fallbackImg};" 
            />
            ${ratingBadge}
            ${episodeBadge}
            ${statusBadge}
          </div>
          <div class="card-body">
            <span class="card-slot">${bits}</span>
            <h2 class="card-title">${escapeHTML(e.title)}</h2>
          </div>
        </a>`;
    }

    let currentFiltered = [];

    function renderFiltered() {
      currentFiltered = applyFilters();
      state.visibleCount = PAGE_SIZE;
      updateURL();

      const visibleItems = currentFiltered.slice(0, state.visibleCount);
      grid.innerHTML = visibleItems.map(cardHTML).join('');

      emptyState.hidden = currentFiltered.length > 0;
      announceResults(visibleItems.length, currentFiltered.length);
      renderLoadMore();
    }

    function appendMore() {
      const previousCount = state.visibleCount;
      state.visibleCount = Math.min(state.visibleCount + PAGE_SIZE, currentFiltered.length);

      const newItems = currentFiltered.slice(previousCount, state.visibleCount);
      grid.insertAdjacentHTML('beforeend', newItems.map(cardHTML).join(''));

      announceResults(state.visibleCount, currentFiltered.length);
      renderLoadMore();

      const newCards = grid.querySelectorAll('.card');
      const firstNewCard = newCards[previousCount];
      if (firstNewCard) firstNewCard.focus({ preventScroll: true });
    }

    function announceResults(shown, total) {
      resultCount.textContent = `Showing ${shown} of ${total} titles`;
    }

    function renderLoadMore() {
      const hasMore = state.visibleCount < currentFiltered.length;
      loadMoreBtn.hidden = !hasMore;
      if (hasMore) {
        const remaining = currentFiltered.length - state.visibleCount;
        loadMoreBtn.textContent = `Load More (${remaining} left)`;
      }
    }

    let searchDebounce;
    function debouncedSearch() {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        state.search = searchInput.value;
        renderFiltered();
      }, 180);
    }

    // Input event covers both typing and clicking the native 'x' to clear
    searchInput.addEventListener('input', debouncedSearch);

    typeSelect.addEventListener('change', () => { state.type = typeSelect.value; renderFiltered(); });
    statusSelect.addEventListener('change', () => { state.status = statusSelect.value; renderFiltered(); });
    genreSelect.addEventListener('change', () => { state.genre = genreSelect.value; renderFiltered(); });
    yearSelect.addEventListener('change', () => { state.year = yearSelect.value; renderFiltered(); });

    clearBtn.addEventListener('click', () => {
      state.search = ''; state.type = 'All'; state.status = 'All'; state.genre = 'All'; state.year = 'All';
      searchInput.value = ''; typeSelect.value = 'All'; statusSelect.value = 'All'; genreSelect.value = 'All'; yearSelect.value = 'All';
      renderFiltered();
    });

    loadMoreBtn.addEventListener('click', appendMore);

    // Initial render
    renderFiltered();
  </script>
</Base>