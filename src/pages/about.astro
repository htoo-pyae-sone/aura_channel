---
import Base from '../layouts/Base.astro';
import SwipeNav from '../components/SwipeNav.astro';

const pages = [
  { href: '/about', label: 'About' },
  { href: '/donate', label: 'Donate' },
  { href: '/terms', label: 'Terms' },
];
---

<Base title="About Us — AURA Channel">
  <article class="page-container">
    <a class="back-link" href="#" onclick="history.back(); return false;">&larr; Back</a>
    <header class="page-header">
      <h1 class="page-title">AURA <span class="highlight">Channel</span></h1>
      <p class="page-subtitle">A Personal Passion Project by One Creator</p>
    </header>

    <div class="content-blocks">
      <section class="content-block glass-card">
        <div class="block-icon icon-welcome">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path></svg>
        </div>
        <h2>AURA Channel အကြောင်း</h2>
        <p>
          AURA Channel ကို Anime ကားတွေကြည့်ရင်း ဘာသာပြန်ရတာ နှစ်သက်သော လူငယ်လေးတဦးမှ ဖန်တီးထားခြင်းဖြစ်ပါသည်။ သို့သော် ထိုလူငယ်လေးသည် အလုပ်တဖက်နှင့် ဖြစ်သောကြောင့် Anime ဘာသာပြန်ဆိုနေသည့် တခြား Channel များကဲ့သို့ Anime ပေါင်းများစွာကို အချိန်နှင့်တပြေးညီ တင်ဆက်နိုင်မည် မဟုတ်ချေ။ 
        </p>
        <p>
          ထိုလူငယ်လေးသည် ဂျပန်စာလဲ မတတ်သလို အင်္ဂလိပ်စာလဲ မကျွမ်းပါ။ ကြည့်ရှုသူတို့ အဆင်ပြေအောင်၊ ဘာသာပြန် ချောမွေ့အောင်၊ စာလုံးပေါင်း မမှားအောင်၊ ဇာတ်ကား Quality မကျအောင်တော့ အမြဲဂရုတစိုက် လုပ်ပေးလေ့ရှိပါသည်။ ထို့ကြောင့် ဇာတ်ကားတင်ချိန် နောက်ကျတာမျိုး၊ ဘာသာပြန်ဆိုထားသည့် စာသားတချို့က ဂျပန်ဘာသာနှင့် မကိုက်ညီတာမျိုးဆို အပြစ်မယူဘဲ ခွင့်လွှတ်ပေးကြဖို့ ကြိုတင်မေတ္တာရပ်ခံအပ်ပါသည်။
        </p>
      </section>
    </div>

    <SwipeNav pages={pages} current="/about" />
  </article>
</Base>
