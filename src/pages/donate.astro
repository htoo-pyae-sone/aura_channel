---
import Base from '../layouts/Base.astro';
---

<Base title="Support Us — AURA Channel">
  <article class="page-container">
    <a class="back-link" href="#" onclick="history.back(); return false;">&larr; Back</a>
    <header class="page-header">
      <h1 class="page-title">Support <span class="highlight">Us</span></h1>
      <p class="page-subtitle">အားပေးသူတိုင်းကို ကျေးဇူးတင်ပါတယ်။</p>
    </header>

    <div class="content-blocks">
      <section class="content-block support-block">
        <div class="block-icon icon-support">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"></path><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path><line x1="6" y1="2" x2="6" y2="4"></line><line x1="10" y1="2" x2="10" y2="4"></line><line x1="14" y1="2" x2="14" y2="4"></line></svg>
        </div>
        <h2>ကော်ဖီဖိုး</h2>
        <p>
          ဘာသာပြန် တင်ဆက်သူမှာ အမြဲအိပ်ရေးမဝ အိပ်ငိုက်တတ်သောကြောင့် ကော်ဖီဝယ်တိုက်ချင်သူများ ဝယ်တိုက်နိုင်ပါတယ်ခင်ဗျာ။
        </p>
        
        <div class="payment-methods">
          <div class="pay-card">
            <span class="pay-name">KPay</span>
            <span class="pay-number">09 123 456 789</span>
            <span class="pay-owner">Aura Channel</span>
          </div>
          <div class="pay-card">
            <span class="pay-name">WavePay</span>
            <span class="pay-number">09 123 456 789</span>
            <span class="pay-owner">Aura Channel</span>
          </div>
          <div class="pay-card">
            <span class="pay-name">AYA Pay</span>
            <span class="pay-number">09 123 456 789</span>
            <span class="pay-owner">Aura Channel</span>
          </div>
        </div>
      </section>
    </div>
  </article>
</Base>