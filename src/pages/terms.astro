---
import Base from '../layouts/Base.astro';
---

<Base title="Terms & Policies — AURA Channel">
  <article class="page-container">
   <a class="back-link" href="/">&larr; Back</a>
    <header class="page-header">
      <h1 class="page-title">Terms & <span class="highlight">Policies</span></h1>
      <p class="page-subtitle">စည်းကမ်းချက်များနှင့် မူပိုင်ခွင့်ဆိုင်ရာ</p>
    </header>

    <div class="content-blocks">
      <section class="content-block terms-block">
        <div class="block-icon icon-terms">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <h2>Terms & Policies</h2>
        <ul>
          <li><strong>No Hosting:</strong> This website does not store, host, or upload any video files on its servers. All media content is provided by non-affiliated third parties.</li>
          <li><strong>Third-Party Links:</strong> All links provided on this site direct to external third-party websites or Telegram bots. We are not responsible for the compliance, copyright, legality, or decency of the content hosted by these external platforms.</li>
          <li><strong>Take Down Request:</strong> If you are a copyright owner and wish to request the removal of specific links pointing to your content, please contact us at aurachannel@gmail.com.</li>
        </ul>
      </section>
    </div>
  </article>
</Base>